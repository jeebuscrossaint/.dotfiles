# coat mako theme: Mountain
# Stefan Weigl-Bosker (https://github.com/sweiglbosker), based on Mountain Theme (https://github.com/mountain-theme/Mountain)

background-color=#0f0f0f
text-color=#f0f0f0
border-color=#262626
progress-color=over #8f8aac
font=Terminess Nerd Font Mono 10

width=400
height=200
margin=16
padding=12,14
border-size=1
border-radius=10
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48
markup=1
actions=1
format=<b>%s</b>\n%b
anchor=top-right
max-visible=5
layer=overlay
sort=-time

on-button-left=dismiss
on-button-right=dismiss-all
on-button-middle=invoke-default-action
on-touch=dismiss

[urgency=low]
border-color=#393939
text-color=#4c4c4c
default-timeout=4000

[urgency=normal]
border-color=#262626
default-timeout=6000

[urgency=high]
border-color=#ac8a8c
text-color=#ac8a8c
default-timeout=0
