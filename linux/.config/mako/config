# coat mako theme: Dimmed Monokai
# FredHappyface (https://github.com/fredHappyface)

background-color=#1e1e1e
text-color=#fcffb8
border-color=#888987
progress-color=over #4e76a1
font=Terminess Nerd Font Mono 10

width=400
height=200
margin=16
padding=12,14
border-size=1
border-radius=10
icons=1
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48
markup=1
actions=1
format=<b>%s</b>\n%b
anchor=top-right
max-visible=5
layer=overlay
sort=-time

on-button-left=dismiss
on-button-right=dismiss-all
on-button-middle=invoke-default-action
on-touch=dismiss

[urgency=low]
border-color=#949593
text-color=#a0a2a0
default-timeout=4000

[urgency=normal]
border-color=#888987
default-timeout=6000

[urgency=high]
border-color=#be3e48
text-color=#be3e48
default-timeout=0
