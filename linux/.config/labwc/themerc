window.inactive.button.unpressed.image.color: #686868
window.inactive.button.hover.image.color: #686868
window.inactive.border.color: #383838

# Padding
padding.height: 2
padding.width: 4

# Menu
menu.items.bg.color: #1c1c1c
menu.items.text.color: #c0c0c0
menu.items.active.bg.color: #ff9200
menu.items.active.text.color: #000000
menu.border.width: 1
menu.border.color: #383838

# OSD
osd.bg.color: #1c1c1c
osd.border.color: #ff9200
osd.border.width: 1
osd.label.text.color: #c0c0c0
