# labwc themerc — coat colors (summerfruit-dark)
# regenerate with: coat apply (once labwc module exists)

border.width: 2

# Active window
window.active.title.bg.color: #1c1c1c
window.active.label.text.color: #f0f0f0
window.active.button.unpressed.image.color: #f0f0f0
window.active.button.hover.image.color: #ff9200
window.active.border.color: #ff9200

# Inactive window
window.inactive.title.bg.color: #0e0e0e
