#!/usr/bin/env python3
# canvas-ical-fetch — fetch and cache Canvas iCal, print path to cache file
# URL is read from ~/.config/canvas/ical-url (one line, not tracked by git)

import os
import sys
import time
import urllib.request

URL_FILE  = os.path.expanduser("~/.config/canvas/ical-url")
CACHE_DIR = os.path.expanduser("~/.cache/canvas")
CACHE     = os.path.join(CACHE_DIR, "calendar.ics")
MAX_AGE   = 300  # seconds — re-fetch every 5 min

def main():
    if not os.path.exists(URL_FILE):
        print(f"error: create {URL_FILE} with your Canvas iCal URL", file=sys.stderr)
        sys.exit(1)

    url = open(URL_FILE).read().strip()
    os.makedirs(CACHE_DIR, exist_ok=True)

    # Use cache if fresh enough
    if os.path.exists(CACHE):
        if time.time() - os.path.getmtime(CACHE) < MAX_AGE:
            print(CACHE)
            return

    try:
        req = urllib.request.Request(url, headers={"User-Agent": "canvas-ical/1.0"})
        with urllib.request.urlopen(req, timeout=10) as r:
            data = r.read()
        with open(CACHE, "wb") as f:
            f.write(data)
    except Exception as e:
        if os.path.exists(CACHE):
            print(CACHE)  # serve stale cache on error
            return
        print(f"error: {e}", file=sys.stderr)
        sys.exit(1)

    print(CACHE)

if __name__ == "__main__":
    main()
