#!/bin/sh
# Cross-platform volume control: wpctl on Linux, sndioctl on OpenBSD
# Usage: volumectl up | down | toggle-mute | [-m] toggle-mute

MIC=0
if [ "$1" = "-m" ]; then
    MIC=1
    shift
fi

if command -v wpctl > /dev/null 2>&1; then
    if [ "$MIC" = "1" ]; then
        TARGET="@DEFAULT_AUDIO_SOURCE@"
    else
        TARGET="@DEFAULT_AUDIO_SINK@"
    fi
    case "$1" in
        up)           wpctl set-volume -l 1.5 "$TARGET" 5%+ ;;
        down)         wpctl set-volume "$TARGET" 5%- ;;
        toggle-mute)  wpctl set-mute "$TARGET" toggle ;;
    esac
else
    # OpenBSD sndioctl
    case "$1" in
        up)
            if [ "$MIC" = "1" ]; then
                current=$(sndioctl -n input.level 2>/dev/null || echo 0)
            else
                current=$(sndioctl -n output.level 2>/dev/null || echo 0)
            fi
            new=$(awk "BEGIN{v=$current+0.05; if(v>1)v=1; printf \"%.2f\",v}")
            if [ "$MIC" = "1" ]; then sndioctl input.level="$new"
            else sndioctl output.level="$new"; fi
            ;;
        down)
            if [ "$MIC" = "1" ]; then
                current=$(sndioctl -n input.level 2>/dev/null || echo 0)
            else
                current=$(sndioctl -n output.level 2>/dev/null || echo 0)
            fi
            new=$(awk "BEGIN{v=$current-0.05; if(v<0)v=0; printf \"%.2f\",v}")
            if [ "$MIC" = "1" ]; then sndioctl input.level="$new"
            else sndioctl output.level="$new"; fi
            ;;
        toggle-mute)
            if [ "$MIC" = "1" ]; then
                current=$(sndioctl -n input.mute 2>/dev/null || echo 0)
                sndioctl input.mute=$(( 1 - current ))
            else
                current=$(sndioctl -n output.mute 2>/dev/null || echo 0)
                sndioctl output.mute=$(( 1 - current ))
            fi
            ;;
    esac
fi
